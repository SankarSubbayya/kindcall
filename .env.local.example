# ---- Convex (frontend) ----
# Populated automatically when you run:  npx convex dev
VITE_CONVEX_URL=

# ---- Respan gateway (used inside Convex actions) ----
# Set these in Convex, not just here:
#   npx convex env set RESPAN_API_KEY <key>
#   npx convex env set KINDCALL_MODEL claude-sonnet-4-6
RESPAN_API_KEY=
RESPAN_BASE_URL=https://api.respan.ai/api
KINDCALL_MODEL=claude-sonnet-4-6

# ---- Photon / Spectrum (optional: family alerts over WhatsApp/iMessage/SMS) ----
# If unset, urgent alerts are logged + stored in Convex instead of sent.
#   npx convex env set PHOTON_API_KEY <key>
#   npx convex env set PHOTON_ENDPOINT <spectrum-send-url>
PHOTON_API_KEY=
PHOTON_ENDPOINT=
PHOTON_CHANNEL=whatsapp
